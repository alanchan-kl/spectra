{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "k6 Load Testing Results",
  "uid": "k6-perf",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Virtual Users (VUs)",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT max(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "VUs" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP requests (per interval)",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "alias": "requests" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Response time",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT percentile(\"value\", 95) AS \"p95\", percentile(\"value\", 90) AS \"p90\", mean(\"value\") AS \"avg\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error rate",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }, "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0 },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT mean(\"value\") * 100 FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "alias": "error %" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Checks (per interval)",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT count(\"value\") FROM \"checks\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "alias": "checks" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response time p95 — by API group",
      "datasource": { "type": "influxdb", "uid": "influxdb_k6" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb_k6" }, "rawQuery": true, "resultFormat": "time_series", "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval), \"group\" fill(null)", "alias": "$tag_group" }
      ]
    }
  ]
}
